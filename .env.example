DATABASE_BACKEND=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Optional admin review destination
TELEGRAM_REVIEW_CHAT_ID=

# Optional runtime tuning (defaults shown)
AI_PROVIDER=groq
AI_API_KEY=
AI_TEXT_MODEL=
AI_ENABLED=true
AI_DAILY_CALL_LIMIT=100
GROQ_RATE_LIMIT_DELAY=3
GROQ_RETRY_BASE_DELAY=20
GROQ_MAX_RETRIES=3
GROQ_DAILY_TEXT_LIMIT=1000
MAX_ITEMS_PER_RUN=5
MAX_POSTS_PER_RUN=5
MAX_POSTS_PER_CATEGORY=2
DAILY_DIGEST_ENABLED=false
DRY_RUN=false
AUTO_POST_ENABLED=true
LOG_LEVEL=INFO
# GitHub Pages URL used by Telegram buttons and digests.
PUBLIC_WEBSITE_URL=https://mahammadsad.github.io/telegram_job_alert_bot
ADMIN_EMAIL=
# DATABASE_PATH=/absolute/path/to/jobs.db (SQLite development only)

# web/.env.local (public values only; never put SERVICE_ROLE here)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_PUBLIC_WEBSITE_URL=https://mahammadsad.github.io/telegram_job_alert_bot
VITE_TELEGRAM_CHANNEL_URL=
