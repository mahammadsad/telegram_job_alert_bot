# Required for live extraction and public posting
GROQ_API_KEY=your_groq_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_or_numeric_id

# Optional admin review destination
TELEGRAM_REVIEW_CHAT_ID=

# Optional runtime tuning (defaults shown)
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_RATE_LIMIT_DELAY=3
GROQ_RETRY_BASE_DELAY=20
GROQ_MAX_RETRIES=3
GROQ_DAILY_TEXT_LIMIT=1000
MAX_ITEMS_PER_RUN=5
DRY_RUN=false
AUTO_POST_ENABLED=true
LOG_LEVEL=INFO
# DATABASE_PATH=/absolute/path/to/jobs.db

